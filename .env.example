# Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
APP_NAME=HRMS

# Database
MONGODB_URI=mongodb://localhost:27017/HRMS

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=30d

# Uploads
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf
UPLOAD_DIR=uploads

# Mail (future)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@hrms.local

# Security
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000,http://192.168.1.51:3000

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Seeder
SEED_OWNER_EMAIL=owner@hrms.local
SEED_OWNER_PASSWORD=Owner@12345
SEED_OWNER_FIRST_NAME=System
SEED_OWNER_LAST_NAME=Owner
SEED_ON_START=false

# Auth Security
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=30
