{
  "name": "hrms-backend",
  "version": "1.0.0",
  "description": "Production-grade HRMS backend — modular monolith for multi-company workforce management",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "prod": "pm2 start ecosystem.config.js --env production",
    "seed": "node -e \"require('dotenv').config(); require('./src/database/connection').connectDatabase().then(() => require('./src/database/seeders').seedDatabase()).then(() => process.exit(0)).catch((e) => { console.error(e); process.exit(1); })\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "hrms",
    "express",
    "mongodb",
    "enterprise"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "csv-parse": "^7.0.1",
    "csv-stringify": "^6.8.1",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.6.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
